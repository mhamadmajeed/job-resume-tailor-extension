{
  "manifest_version": 3,
  "name": "Job Resume Tailor",
  "description": "Locally tailors a stored resume draft to keywords found on job listing pages.",
  "version": "2.0.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://job-resume-tailor-server.*.workers.dev/*"
  ],
  "action": {
    "default_title": "Tailor resume",
    "default_popup": "popup.html"
  }
}
